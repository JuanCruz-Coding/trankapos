{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run typecheck 2>&1 || exit 2",
            "asyncRewake": true,
            "timeout": 180,
            "statusMessage": "Verificando tipos TypeScript…",
            "rewakeSummary": "Errores de TypeScript detectados"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-env.cjs"
          }
        ]
      }
    ]
  }
}
